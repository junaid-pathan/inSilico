# Copy this file to `.env` (in this same project root folder) and fill in your key.
# `.env` is gitignored, so it stays local.

# Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenClaw gateway (used by the assistant bridge at POST /whobee/chat)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_HOOKS_PATH=/hooks
OPENCLAW_HOOK_TOKEN=your_openclaw_hook_token_here
# Optional:
# OPENCLAW_AGENT_NAME=Whobee
# OPENCLAW_AGENT_ID=main
# OPENCLAW_MODEL=google/gemini-2.5-flash
# OPENCLAW_THINKING=low
# OPENCLAW_TIMEOUT_SECONDS=60
